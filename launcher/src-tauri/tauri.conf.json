{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atem Overseer",
  "version": "0.2.0",
  "identifier": "com.allansargeant.atem-overseer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Atem Overseer",
        "width": 460,
        "height": 500,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "deb", "rpm"],
    "resources": [
      "launcher.toml",
      "node*",
      "atem-overseer-app/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist"
    }
  }
}
